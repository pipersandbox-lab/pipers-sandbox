<title>Piper'd Sandbox - Meta Ads Simulator</title>
<style>
:root{
  --cream:#F7F0E3;--sage:#A3B18A;--sage2:#DDE5D2;--charcoal:#2F2F2F;--pink:#F4B6C2;--blue:#6C8AE4;--gold:#F6C85F;--white:#fff;--line:#D9D3C7;
}
*{box-sizing:border-box;margin:0;padding:0}body{font-family:Inter,-apple-system,BlinkMacSystemFont,"Segoe UI",sans-serif;background:var(--cream);color:var(--charcoal);font-size:15px}button,input,select,textarea{font-family:inherit}.topbar{background:var(--white);border-bottom:3px solid var(--sage2);padding:14px 20px;display:flex;align-items:center;gap:14px;position:sticky;top:0;z-index:20}.brand{display:flex;align-items:center;gap:12px}.logo{width:54px;height:54px;border-radius:18px;background:var(--sage2);display:flex;align-items:center;justify-content:center;border:2px solid var(--sage)}.logo svg{width:42px;height:42px}.brand h1{font-size:22px;line-height:1}.brand small{font-weight:700;color:#667456}.pill{border:2px solid var(--sage2);background:#fff;border-radius:999px;padding:8px 12px;font-weight:700;font-size:13px}.spacer{flex:1}.teacher-tag{background:#fff7d6;border:2px solid #efd277;border-radius:999px;padding:8px 12px;font-weight:800}.layout{display:grid;grid-template-columns:260px 1fr;min-height:calc(100vh - 85px)}.sidebar{background:#fffef9;border-right:3px solid var(--sage2);padding:18px}.navcard{background:#fff;border:2px solid var(--line);border-radius:18px;padding:16px;margin-bottom:14px;box-shadow:0 4px 0 rgba(0,0,0,.04)}.navcard h3{font-size:15px;margin-bottom:8px}.navcard p{font-size:13px;color:#666;line-height:1.35}.main{padding:22px;overflow:auto}.toolbar{display:flex;gap:10px;align-items:center;flex-wrap:wrap;margin-bottom:16px}.btn{border:0;border-radius:14px;padding:11px 16px;font-weight:800;cursor:pointer}.btn.primary{background:var(--sage);color:#fff}.btn.blue{background:var(--blue);color:#fff}.btn.light{background:#fff;border:2px solid var(--line);color:var(--charcoal)}.btn:disabled{opacity:.45;cursor:not-allowed}.board{background:#fff;border:3px solid var(--sage2);border-radius:24px;box-shadow:0 12px 30px rgba(60,60,60,.08);overflow:hidden}.board-head{background:linear-gradient(90deg,var(--sage2),#fff4d9);padding:16px 18px;display:flex;align-items:center;gap:12px;border-bottom:2px solid var(--line)}.board-head h2{font-size:23px}.table{width:100%;border-collapse:collapse;background:#fff}th{background:#fbfaf4;color:#6a6a6a;text-align:left;padding:13px;border-bottom:2px solid var(--line);font-size:13px}td{padding:14px;border-bottom:1px solid #eee;font-size:14px}tr:hover{background:#fbfaf4}.campaign-name{font-weight:850;color:#496a3a;cursor:pointer}.metric-good{color:#1a8f52;font-weight:850}.metric-warn{color:#c17a00;font-weight:850}.empty{text-align:center;padding:70px 20px}.empty .big{font-size:64px;margin-bottom:8px}.empty h2{font-size:28px;margin-bottom:8px}.empty p{color:#676767;margin-bottom:18px}.modal-bg{position:fixed;inset:0;background:rgba(47,47,47,.52);z-index:50;display:flex;align-items:center;justify-content:center;padding:18px}.modal{width:min(980px,96vw);height:min(760px,92vh);background:#fff;border-radius:26px;overflow:hidden;display:flex;flex-direction:column;box-shadow:0 30px 80px rgba(0,0,0,.3)}.modal-top{padding:18px 22px;border-bottom:2px solid var(--sage2);display:flex;align-items:center;gap:12px}.modal-top h2{font-size:22px}.x{margin-left:auto;background:#fff;border:2px solid var(--line);border-radius:12px;padding:6px 10px;font-weight:900;cursor:pointer}.modal-body{display:grid;grid-template-columns:240px 1fr;min-height:0;flex:1}.steps{background:#fbfaf4;border-right:2px solid var(--sage2);padding:18px 0}.step{padding:13px 18px;display:flex;gap:10px;align-items:center;color:#777;font-weight:750}.step.active{background:#fff;color:#496a3a;border-left:6px solid var(--sage);padding-left:12px}.step.done{color:#1a8f52}.bubble{width:26px;height:26px;border-radius:50%;background:#ddd;display:flex;align-items:center;justify-content:center;color:#fff;font-size:12px;font-weight:900}.step.active .bubble{background:var(--sage)}.step.done .bubble{background:#1a8f52}.content{padding:28px;overflow:auto}.content h2{font-size:28px;margin-bottom:8px}.subtitle{color:#666;margin-bottom:22px}.field{margin-bottom:18px}.label{font-weight:850;margin-bottom:7px;display:block}.hint{font-size:13px;color:#6a6a6a;margin-top:6px}input,textarea,select{width:100%;border:2px solid var(--line);border-radius:14px;padding:12px;font-size:15px}input:focus,textarea:focus,select:focus{outline:none;border-color:var(--sage)}.cards{display:grid;gap:12px}.option{border:3px solid #eee;border-radius:20px;padding:15px;display:flex;gap:14px;cursor:pointer;align-items:flex-start}.option:hover{border-color:var(--sage)}.option.selected{background:#f3f8ec;border-color:var(--sage)}.emoji{font-size:28px}.option h3{font-size:18px;margin-bottom:4px}.option p{color:#666;font-size:13px;line-height:1.35}.alert{border-radius:16px;padding:14px 16px;margin:14px 0;line-height:1.4}.alert.info{background:#eef3ff;border-left:6px solid var(--blue)}.alert.warn{background:#fff7d6;border-left:6px solid var(--gold)}.footer{border-top:2px solid var(--sage2);padding:15px 22px;display:flex;align-items:center;justify-content:space-between}.detail-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:12px;margin-bottom:16px}.stat{background:#fff;border:3px solid var(--sage2);border-radius:20px;padding:16px}.stat label{display:block;text-transform:uppercase;font-size:11px;font-weight:900;color:#777;margin-bottom:8px}.stat strong{font-size:25px}.small-table-wrap{overflow:auto}.cat-tip{background:#fff;border:3px dashed var(--sage);border-radius:22px;padding:16px;margin-top:16px;display:flex;gap:12px;align-items:flex-start}.cat-tip b{color:#496a3a}.fab{position:fixed;right:22px;bottom:22px;border:0;width:70px;height:70px;border-radius:50%;background:linear-gradient(135deg,var(--sage),var(--pink));box-shadow:0 12px 32px rgba(0,0,0,.22);font-size:35px;cursor:pointer;z-index:40}.coach{position:fixed;right:22px;bottom:102px;width:390px;max-width:calc(100vw - 44px);height:510px;max-height:calc(100vh - 130px);background:#fff;border:3px solid var(--sage2);border-radius:26px;box-shadow:0 20px 60px rgba(0,0,0,.25);z-index:40;display:none;flex-direction:column;overflow:hidden}.coach-head{background:linear-gradient(90deg,var(--sage),var(--pink));padding:14px 16px;color:#fff;display:flex;align-items:center;gap:12px}.coach-head button{margin-left:auto}.messages{flex:1;overflow:auto;background:#fbfaf4;padding:14px;display:flex;flex-direction:column;gap:10px}.msg{padding:11px 13px;border-radius:18px;max-width:88%;line-height:1.42}.msg.bot{background:#fff;border:2px solid var(--sage2);align-self:flex-start}.msg.user{background:var(--sage);color:#fff;align-self:flex-end}.coach-input{display:flex;gap:8px;padding:12px;border-top:2px solid var(--sage2)}.coach-input input{border-radius:999px}.coach-input button{border-radius:50%;width:42px}.badge{display:inline-block;border-radius:999px;padding:5px 9px;font-size:12px;font-weight:850}.learn{background:#fff7d6;color:#956500}.opt{background:#eaf6e8;color:#287a3e}@media(max-width:800px){.layout{grid-template-columns:1fr}.sidebar{display:none}.modal-body{grid-template-columns:1fr}.steps{display:flex;overflow:auto;border-right:0;border-bottom:2px solid var(--sage2);padding:8px}.step span.txt{display:none}.content{padding:18px}.topbar{flex-wrap:wrap}.teacher-tag{display:none}}
</style>
</head>
<body>
<header class="topbar">
  <div class="brand"><div class="logo" aria-label="Piper cat logo"> <svg viewBox="0 0 120 120" role="img"><path d="M32 42 21 18l28 16M88 42l11-24-28 16" fill="#A3B18A" stroke="#2F2F2F" stroke-width="5" stroke-linejoin="round"/><circle cx="60" cy="62" r="38" fill="#fff" stroke="#2F2F2F" stroke-width="5"/><path d="M38 61c4-8 14-8 18 0M64 61c4-8 14-8 18 0" fill="none" stroke="#2F2F2F" stroke-width="5" stroke-linecap="round"/><path d="M54 73h12l-6 6z" fill="#F4B6C2" stroke="#2F2F2F" stroke-width="3"/><path d="M50 84q10 8 20 0" fill="none" stroke="#2F2F2F" stroke-width="4" stroke-linecap="round"/><path d="M18 98h84" stroke="#2F2F2F" stroke-width="5" stroke-linecap="round"/><rect x="31" y="91" width="58" height="18" rx="6" fill="#DDE5D2" stroke="#2F2F2F" stroke-width="4"/><circle cx="60" cy="100" r="4" fill="#2F2F2F"/></svg></div><div><h1>Piper’d Sandbox™</h1><small>Meta Ads Simulator for Classrooms</small></div></div>
  <span class="pill">Practice Account: PIPER123</span><span class="pill">No real ad spend</span><div class="spacer"></div><span class="teacher-tag">Smart Board Ready ✨</span>
</header>
<div class="layout"><aside class="sidebar"><div class="navcard"><h3>Teacher Goal</h3><p>Students practice campaign decisions without using real money or logging into Meta.</p></div><div class="navcard"><h3>Student Mission</h3><p>Create a campaign, choose objective, audience, budget, placement, and creative.</p></div><div class="navcard"><h3>Piper Tip</h3><p>Click the cat coach for help. Results are simulated for classroom practice.</p></div></aside><main class="main" id="app"></main></div>
<button class="fab" onclick="toggleCoach()">🐱</button><section class="coach" id="coach"><div class="coach-head"><strong>🐱 Piper Coach</strong><button class="x" onclick="toggleCoach()">×</button></div><div class="messages" id="messages"></div><div class="coach-input"><input id="coachInput" placeholder="Ask about CPR, CTR, budget..." onkeydown="if(event.key==='Enter')sendCoach()"><button class="btn primary" onclick="sendCoach()">↑</button></div></section>
<script>
const objectives=[['awareness','👁️','Awareness','Show your ad to people likely to remember it.'],['traffic','🔗','Traffic','Send people to a website or landing page.'],['engagement','💬','Engagement','Get likes, comments, shares, and interactions.'],['leads','📋','Leads','Collect signups or customer info.'],['sales','💰','Sales','Optimize for purchases or conversions.']];
const audiences=[['broad','Advantage+ Broad','Meta has room to find the right people.','8M+'],['interest','Interest Targeting','Choose one or two relevant interests.','850K'],['lookalike','Lookalike Audience','Similar to existing customers.','2.2M'],['narrow','Narrow Targeting','Very specific, but can get expensive.','65K']];
const placements=[['auto','Advantage+ Placements','Recommended for beginners'],['feeds','Feeds only','Facebook + Instagram feeds'],['reels','Reels + Stories','Vertical video placements'],['manual','Manual Mix','Teacher/student selected mix']];
const steps=['Objective','Audience','Placement','Budget','Creative','Review'];
let campaigns=JSON.parse(localStorage.getItem('piper_campaigns')||'[]');let view='home',selected=null,step=0,draft={};
function save(){localStorage.setItem('piper_campaigns',JSON.stringify(campaigns))}
function resetDraft(){draft={name:'',objective:'',audience:'broad',placement:'auto',budget:35,headline:'',body:'',cta:'Learn More',category:false}}
function sim(c){let days=[],of={awareness:8,traffic:12,engagement:10,leads:18,sales:22},af={broad:1,interest:1.15,lookalike:1.3,narrow:1.8},pf={auto:.92,feeds:1,reels:.95,manual:1.1};let baseCPM=(of[c.objective]||12)*(af[c.audience]||1)*(pf[c.placement]||1);let baseCTR={awareness:.009,traffic:.022,engagement:.018,leads:.016,sales:.014}[c.objective]||.016;let conv={awareness:.004,traffic:.008,engagement:.006,leads:.045,sales:.035}[c.objective]||.01;let boost=c.headline.length>12&&c.body.length>35?1.18:.9;if(c.placement==='auto')boost*=1.08;if(c.audience==='narrow')boost*=.82;for(let i=1;i<=14;i++){let learning=i<=7?(0.58+i*.06):1;let spend=c.budget*(.92+Math.random()*.16);let cpm=baseCPM*(.9+Math.random()*.22);let impressions=Math.floor((spend/cpm)*1000);let ctr=baseCTR*learning*boost*(.82+Math.random()*.35);let clicks=Math.floor(impressions*ctr);let conversions=Math.floor(clicks*conv*learning*(.75+Math.random()*.5));let revenue=conversions*45;days.push({day:i,phase:i<=7?'Learning':'Optimized',spend:+spend.toFixed(2),impressions,clicks,ctr:+(ctr*100).toFixed(2),conversions,cpr:conversions?+(spend/conversions).toFixed(2):0,revenue:+revenue.toFixed(2),roas:spend?+(revenue/spend).toFixed(2):0})}return days}
function totals(days){let t=days.reduce((a,d)=>{a.spend+=d.spend;a.impressions+=d.impressions;a.clicks+=d.clicks;a.conversions+=d.conversions;a.revenue+=d.revenue;return a},{spend:0,impressions:0,clicks:0,conversions:0,revenue:0});t.ctr=t.impressions?+(t.clicks/t.impressions*100).toFixed(2):0;t.cpr=t.conversions?+(t.spend/t.conversions).toFixed(2):0;t.roas=t.spend?+(t.revenue/t.spend).toFixed(2):0;return t}
function render(){let app=document.getElementById('app');if(view==='detail')return detail(app);app.innerHTML=`<div class="toolbar"><button class="btn primary" onclick="openCreate()">+ Create Campaign</button><button class="btn light" onclick="clearData()">Reset Classroom Data</button><button class="btn blue" onclick="teacherMode()">Teacher Prompt</button></div><section class="board"><div class="board-head"><h2>Campaign Dashboard</h2><span class="pill">Simulated results</span></div>${campaigns.length?table():empty()}</section>`}
function empty(){return `<div class="empty"><div class="big">🐾</div><h2>No campaigns yet</h2><p>Start a classroom simulation by creating your first Meta-style ad campaign.</p><button class="btn primary" onclick="openCreate()">Create First Campaign</button></div>`}
function table(){return `<div class="small-table-wrap"><table class="table"><thead><tr><th>Campaign</th><th>Objective</th><th>Audience</th><th>Budget</th><th>Spend</th><th>Reach/Impr.</th><th>CTR</th><th>CPR</th><th>ROAS</th></tr></thead><tbody>${campaigns.map(c=>{let t=totals(c.days);return `<tr onclick="selected='${c.id}';view='detail';render()"><td><span class="campaign-name">${esc(c.name)}</span></td><td>${objName(c.objective)}</td><td>${audName(c.audience)}</td><td>$${c.budget}/day</td><td>$${t.spend.toFixed(2)}</td><td>${t.impressions.toLocaleString()}</td><td class="${t.ctr>=1?'metric-good':'metric-warn'}">${t.ctr}%</td><td>${t.cpr?'$'+t.cpr:'—'}</td><td class="${t.roas>=2?'metric-good':'metric-warn'}">${t.roas}x</td></tr>`}).join('')}</tbody></table></div>`}
function detail(app){let c=campaigns.find(x=>x.id===selected),t=totals(c.days);app.innerHTML=`<div class="toolbar"><button class="btn light" onclick="view='home';render()">← Back</button><button class="btn primary" onclick="openCreate()">+ New Campaign</button></div><section class="board"><div class="board-head"><h2>${esc(c.name)}</h2><span class="pill">${objName(c.objective)}</span></div><div style="padding:18px"><div class="detail-grid"><div class="stat"><label>Spent</label><strong>$${t.spend.toFixed(2)}</strong></div><div class="stat"><label>Impressions</label><strong>${t.impressions.toLocaleString()}</strong></div><div class="stat"><label>Clicks</label><strong>${t.clicks}</strong></div><div class="stat"><label>CTR</label><strong>${t.ctr}%</strong></div><div class="stat"><label>Results</label><strong>${t.conversions}</strong></div><div class="stat"><label>CPR</label><strong>${t.cpr?'$'+t.cpr:'—'}</strong></div><div class="stat"><label>ROAS</label><strong>${t.roas}x</strong></div></div><div class="cat-tip"><span style="font-size:32px">🐱</span><p><b>Piper says:</b> CTR near or above 1% means the message is connecting. High CPR means students should improve targeting, creative, or landing-page fit. The first 7 days show the Learning Phase.</p></div><div class="small-table-wrap" style="margin-top:16px"><table class="table"><thead><tr><th>Day</th><th>Phase</th><th>Spend</th><th>Impressions</th><th>Clicks</th><th>CTR</th><th>Results</th><th>CPR</th><th>ROAS</th></tr></thead><tbody>${c.days.map(d=>`<tr><td><b>Day ${d.day}</b></td><td><span class="badge ${d.phase==='Learning'?'learn':'opt'}">${d.phase}</span></td><td>$${d.spend}</td><td>${d.impressions.toLocaleString()}</td><td>${d.clicks}</td><td>${d.ctr}%</td><td>${d.conversions}</td><td>${d.cpr?'$'+d.cpr:'—'}</td><td>${d.roas}x</td></tr>`).join('')}</tbody></table></div></div></section>`}
function openCreate(){resetDraft();step=0;modal()}
function modal(){document.getElementById('createModal')?.remove();let div=document.createElement('div');div.className='modal-bg';div.id='createModal';div.innerHTML=`<div class="modal"><div class="modal-top"><h2>Create a Campaign</h2><span class="pill">Step ${step+1} of ${steps.length}</span><button class="x" onclick="closeModal()">×</button></div><div class="modal-body"><aside class="steps">${steps.map((s,i)=>`<div class="step ${i===step?'active':''} ${i<step?'done':''}"><span class="bubble">${i<step?'✓':i+1}</span><span class="txt">${s}</span></div>`).join('')}</aside><section class="content">${stepHTML()}</section></div><div class="footer"><button class="btn light" onclick="${step?'prev()':'closeModal()'}">${step?'← Back':'Cancel'}</button><span class="hint">Piper’d Sandbox™ | Practice. Learn. Grow.</span>${step<5?`<button class="btn primary" ${canNext()?'':'disabled'} onclick="next()">Next →</button>`:`<button class="btn primary" onclick="publish()">Publish Simulation 🚀</button>`}</div></div>`;document.body.appendChild(div)}
function stepHTML(){if(step===0)return `<h2>Choose your campaign objective</h2><p class="subtitle">What do you want people to do after seeing your ad?</p><div class="field"><label class="label">Campaign name</label><input value="${esc(draft.name)}" oninput="draft.name=this.value;modal()" placeholder="Example: School Spirit Hoodie Launch"></div><div class="cards">${objectives.map(o=>`<div class="option ${draft.objective===o[0]?'selected':''}" onclick="draft.objective='${o[0]}';modal();say('${tipObjective(o[0])}')"><div class="emoji">${o[1]}</div><div><h3>${o[2]}</h3><p>${o[3]}</p></div></div>`).join('')}</div>`;if(step===1)return `<h2>Build your audience</h2><p class="subtitle">Don’t overdo targeting. Beginners should start broad.</p><div class="cards">${audiences.map(a=>`<div class="option ${draft.audience===a[0]?'selected':''}" onclick="draft.audience='${a[0]}';modal()"><div class="emoji">👥</div><div style="flex:1"><h3>${a[1]}</h3><p>${a[2]}</p></div><b>${a[3]}</b></div>`).join('')}</div><div class="alert info"><b>Teaching point:</b> Meta targets who people are — interests, behavior, demographics — not what they search.</div>`;if(step===2)return `<h2>Pick placements</h2><p class="subtitle">Where should the ads appear?</p><div class="cards">${placements.map(p=>`<div class="option ${draft.placement===p[0]?'selected':''}" onclick="draft.placement='${p[0]}';modal()"><div class="emoji">📱</div><div><h3>${p[1]}</h3><p>${p[2]}</p></div></div>`).join('')}</div><div class="alert info"><b>Piper tip:</b> Advantage+ Placements is the beginner-friendly autopilot option.</div>`;if(step===3)return `<h2>Set the budget</h2><p class="subtitle">Daily budget is recommended for beginners.</p><div class="field"><label class="label">Daily Budget</label><input type="number" min="5" value="${draft.budget}" oninput="draft.budget=Number(this.value);modal()"><p class="hint">14-day simulated total: $${(draft.budget*14).toFixed(2)}</p></div><label style="display:flex;gap:10px;align-items:center;margin:10px 0 16px"><input style="width:auto" type="checkbox" ${draft.category?'checked':''} onchange="draft.category=this.checked;modal()"> Special Ad Category? Credit, jobs, housing, or politics require this.</label><div class="alert warn"><b>Learning Phase:</b> Meta needs around 50 conversion events to optimize. Early results may fluctuate.</div>`;if(step===4)return `<h2>Create the ad</h2><p class="subtitle">UGC-style creative, a fast hook, and one clear message work best.</p><div class="field"><label class="label">Headline</label><input maxlength="40" value="${esc(draft.headline)}" oninput="draft.headline=this.value;modal()" placeholder="Learn Ads Without Spending Money"></div><div class="field"><label class="label">Primary text</label><textarea maxlength="125" rows="4" oninput="draft.body=this.value;modal()" placeholder="Practice campaign setup, targeting, creative, and metrics in a safe classroom simulator.">${esc(draft.body)}</textarea></div><div class="field"><label class="label">Call to action</label><select onchange="draft.cta=this.value;modal()"><option>Learn More</option><option>Sign Up</option><option>Shop Now</option><option>Get Offer</option></select></div><div class="alert info"><b>3-second rule:</b> If the hook does not stop the scroll, the ad fails.</div>`;return `<h2>Review before publishing</h2><p class="subtitle">This will create simulated results. No money is spent.</p><div class="board" style="padding:18px"><p><b>Name:</b> ${esc(draft.name)}</p><p><b>Objective:</b> ${objName(draft.objective)}</p><p><b>Audience:</b> ${audName(draft.audience)}</p><p><b>Placement:</b> ${placeName(draft.placement)}</p><p><b>Budget:</b> $${draft.budget}/day</p><p><b>Special Ad Category:</b> ${draft.category?'Yes':'No'}</p><p><b>Headline:</b> ${esc(draft.headline)}</p><p><b>Primary Text:</b> ${esc(draft.body)}</p></div>`}
function canNext(){if(step===0)return draft.name.trim()&&draft.objective;if(step===4)return draft.headline.trim()&&draft.body.trim();return true}function next(){if(canNext()){step++;modal();coachStep()}}function prev(){step--;modal()}function closeModal(){document.getElementById('createModal')?.remove()}function publish(){let c={...draft,id:'c'+Date.now(),days:sim(draft)};campaigns.unshift(c);save();closeModal();view='detail';selected=c.id;render();say('Boom! Your campaign is live. Now review CTR, CPR, Frequency concepts, Reach/Impressions, and Learning Phase results. 🎉')}
function clearData(){if(confirm('Reset all classroom campaign data?')){campaigns=[];save();render()}}function teacherMode(){say('Teacher prompt: Ask students which choice they would change first if CTR is below 1% — creative, audience, or objective?')}
function objName(id){return (objectives.find(o=>o[0]===id)||['','','—'])[2]}function audName(id){return (audiences.find(a=>a[0]===id)||['','—'])[1]}function placeName(id){return (placements.find(p=>p[0]===id)||['','—'])[1]}function esc(s){return String(s||'').replace(/[&<>"]/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;'}[m]))}
function tipObjective(id){return {traffic:'Traffic is a good beginner objective when you want website visits.',engagement:'Engagement is great for learning what content people react to.',sales:'Sales is powerful, but it needs stronger tracking and enough data.',leads:'Leads works well when you need signups or customer information.',awareness:'Awareness helps people remember a new brand or offer.'}[id]||'Good choice!'}
function toggleCoach(){let c=document.getElementById('coach');c.style.display=c.style.display==='flex'?'none':'flex';if(!document.getElementById('messages').children.length)say('Hi, I’m Piper! I can explain objectives, audiences, Learning Phase, CTR, CPR, frequency, and creative tips. 🐾')}
function say(text){let m=document.getElementById('messages');let d=document.createElement('div');d.className='msg bot';d.textContent=text;m.appendChild(d);m.scrollTop=m.scrollHeight;document.getElementById('coach').style.display='flex'}function sendCoach(){let input=document.getElementById('coachInput'),text=input.value.trim();if(!text)return;let m=document.getElementById('messages');let u=document.createElement('div');u.className='msg user';u.textContent=text;m.appendChild(u);input.value='';let t=text.toLowerCase();let ans=t.includes('ctr')?'CTR means click-through rate. Around 1% is a useful beginner benchmark. Below that, improve the hook, headline, or creative.':t.includes('cpr')||t.includes('cost')?'CPR means cost per result. If CPR is high, try a stronger creative, broader audience, or better landing page fit.':t.includes('learning')?'Learning Phase is when Meta needs data to optimize. Around 50 conversion events helps the system learn who should see the ad.':t.includes('audience')?'Start broad. Too many interests can make the audience small and expensive.':t.includes('budget')?'Daily budget is beginner-friendly because it is easier to control while testing.':t.includes('creative')||t.includes('hook')?'UGC-style, platform-native creative usually beats polished ads. Hook attention in the first 3 seconds.':'Ask me about CTR, CPR, Learning Phase, budget, audience, placements, or creative.';setTimeout(()=>say(ans),250)}function coachStep(){let tips=['','Audience tip: start broad and let Meta learn.','Placement tip: Advantage+ works like autopilot for beginners.','Budget tip: daily budget is easiest for classroom simulations.','Creative tip: UGC style and a 3-second hook matter most.','Review tip: check objective, audience, and budget before publishing.'];if(tips[step])say(tips[step])}
render();
